# Base URL of the Clickfold API (see the clickfold-api repo)
NEXT_PUBLIC_API_URL=http://localhost:9000/api

# Google OAuth client ID (shared with the API for token verification)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<your-google-client-id>

# Public URL this app is deployed at (used for sitemap/robots/OG metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
